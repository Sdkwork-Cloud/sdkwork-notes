{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Notes Studio",
  "version": "0.1.0",
  "identifier": "com.sdkwork.notes-studio",
  "build": {
    "beforeDevCommand": "pnpm run dev:tauri",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1421"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Notes Studio",
        "width": 1480,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "visible": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
